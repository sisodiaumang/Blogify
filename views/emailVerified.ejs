<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head')%>
    <title>Account Verified | Blogify</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #fcfaf7;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .success-container {
            max-width: 450px;
            margin: auto;
            padding: 60px 40px;
            background: #ffffff;
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            border: 1px solid #eee;
            text-align: center;
        }

        .auth-header {
            font-family: 'DM Serif Display', serif;
            font-size: 2.2rem;
            color: #2d3e50;
            margin-bottom: 20px;
        }

        .success-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 70px;
            height: 70px;
            background-color: #e8f5e9;
            color: #2e7d32;
            font-size: 32px;
            border-radius: 50%;
            margin-bottom: 25px;
        }

        .text {
            color: #666;
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 35px;
        }

        .btn-login {
            display: block;
            width: 100%;
            background-color: #2d3e50;
            color: #fff;
            text-decoration: none;
            padding: 14px;
            font-weight: 600;
            border-radius: 4px;
            transition: background 0.3s;
            box-sizing: border-box;
        }

        .btn-login:hover {
            background-color: #000;
            color: #fff;
        }
    </style>
</head>

<body>
    <%- include('./partials/nav')%>

    <div class="container d-flex flex-grow-1">
        <div class="success-container">
            <div class="success-icon">✓</div>
            <h1 class="auth-header">Account Verified!</h1>
            <p class="text">
                Your email has been successfully confirmed. Your Blogify account is now active and ready to go.
            </p>
            <a href="/user/signin" class="btn-login">Sign In to Your Account</a>
        </div>
    </div>

    <%- include('./partials/script')%>
</body>

</html>