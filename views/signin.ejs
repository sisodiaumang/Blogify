<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head')%>
    <title>Signin | The Feed</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #fcfaf7;
            --accent-color: #2d3e50;
            --text-main: #1a1a1a;
            --input-bg: #f9f9f9;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .signin-wrapper {
            display: flex;
            flex-grow: 1;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .signin-container {
            width: 100%;
            max-width: 400px;
            background: #ffffff;
            padding: 45px;
            border-radius: 12px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.04);
            border: 1px solid #eee;
            transition: transform 0.3s ease;
        }

        .auth-header {
            font-family: 'DM Serif Display', serif;
            font-size: 2.4rem;
            color: var(--accent-color);
            text-align: center;
            margin-bottom: 8px;
        }

        .auth-subtitle {
            text-align: center;
            font-size: 0.9rem;
            color: #888;
            margin-bottom: 35px;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .label-wrapper {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .form-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: #666;
            margin: 0;
        }

        .forgot-link {
            font-size: 0.7rem;
            color: #aaa;
            text-decoration: none;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: color 0.2s;
        }

        .forgot-link:hover {
            color: var(--accent-color);
        }

        .password-wrapper {
            position: relative;
        }

        .form-control {
            border: 1px solid #e8e8e8;
            border-radius: 6px;
            padding: 14px;
            background-color: var(--input-bg);
            transition: all 0.2s ease;
            width: 100%;
            font-size: 0.95rem;
            outline: none;
        }

        .form-control:focus {
            background-color: #fff;
            border-color: var(--accent-color);
            box-shadow: 0 0 0 4px rgba(45, 62, 80, 0.05);
        }

        .toggle-password {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            font-size: 0.65rem;
            font-weight: 800;
            color: var(--accent-color);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            user-select: none;
            opacity: 0.6;
        }

        .toggle-password:hover {
            opacity: 1;
        }

        .btn-signin {
            width: 100%;
            background-color: var(--accent-color);
            color: #fff;
            border: none;
            padding: 14px;
            font-weight: 600;
            font-size: 1rem;
            border-radius: 6px;
            margin-top: 10px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .btn-signin:hover {
            background-color: #1a2530;
            box-shadow: 0 8px 15px rgba(45, 62, 80, 0.2);
        }

        .footer-link {
            text-align: center;
            margin-top: 30px;
            font-size: 0.9rem;
            color: #888;
        }

        .footer-link a {
            color: var(--accent-color);
            text-decoration: none;
            font-weight: 700;
            margin-left: 5px;
        }

        .footer-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>
    <%- include('./partials/nav')%>

    <div class="signin-wrapper">
        <div class="signin-container">
            <h1 class="auth-header">Welcome Back.</h1>
            <p class="auth-subtitle">Please enter your details to sign in.</p>

            <form action="/user/signin" method="POST">
                <div class="form-group">
                    <label for="email" class="form-label">Email address</label>
                    <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com" required>
                </div>

                <div class="form-group">
                    <div class="label-wrapper">
                        <label for="password" class="form-label">Password</label>
                        <a href="/user/forgot-password" class="forgot-link">Forgot?</a>
                    </div>
                    <div class="password-wrapper">
                        <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" required>
                        <span class="toggle-password" id="togglePassword">Show</span>
                    </div>
                </div>

                <button type="submit" class="btn-signin">Sign In</button>
            </form>

            <div class="footer-link">
                Don't have an account? <a href="/user/signup">Join us</a>
            </div>
        </div>
    </div>

    <%- include('./partials/script')%>

    <script>
        const togglePassword = document.querySelector('#togglePassword');
        const passwordField = document.querySelector('#password');

        togglePassword.addEventListener('click', function () {
            // Toggle the type attribute
            const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordField.setAttribute('type', type);

            // Toggle the text
            this.textContent = type === 'password' ? 'Show' : 'Hide';
        });
    </script>
</body>

</html>