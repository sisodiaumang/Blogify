<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head')%>
    <title>New Password | Blogify</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #fcfaf7;
            --accent-color: #2d3e50;
            --text-main: #1a1a1a;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .auth-wrapper {
            display: flex;
            flex-grow: 1;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .auth-container {
            width: 100%;
            max-width: 400px;
            background: #ffffff;
            padding: 45px;
            border-radius: 12px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.04);
            border: 1px solid #eee;
        }

        .auth-header {
            font-family: 'DM Serif Display', serif;
            font-size: 2.2rem;
            color: var(--accent-color);
            text-align: center;
            margin-bottom: 12px;
        }

        .auth-subtitle {
            text-align: center;
            font-size: 0.9rem;
            color: #888;
            margin-bottom: 35px;
            line-height: 1.5;
        }

        .form-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: #666;
            margin-bottom: 10px;
            display: block;
        }

        .form-control {
            border: 1px solid #e8e8e8;
            border-radius: 6px;
            padding: 14px;
            background-color: #f9f9f9;
            width: 100%;
            font-size: 0.95rem;
            outline: none;
            margin-bottom: 20px;
        }

        .form-control:focus {
            background-color: #fff;
            border-color: var(--accent-color);
        }

        .btn-auth {
            width: 100%;
            background-color: var(--accent-color);
            color: #fff;
            border: none;
            padding: 14px;
            font-weight: 600;
            font-size: 1rem;
            border-radius: 6px;
            margin-top: 10px;
            cursor: pointer;
        }

        .btn-auth:hover {
            background-color: #1a2530;
        }

        .password-hint {
            font-size: 0.75rem;
            color: #999;
            margin-top: -10px;
            margin-bottom: 20px;
        }
    </style>
</head>

<body>
    <%- include('./partials/nav')%>

    <div class="auth-wrapper">
        <div class="auth-container">
            <h1 class="auth-header">Secure Account.</h1>
            <p class="auth-subtitle">
                Create a strong, unique password to keep your stories and ideas safe.
            </p>

            <form action="/user/resetPassword/<%= otp %>" method="POST">
                <div class="form-group">
                    <label for="password" class="form-label">New Password</label>
                    <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" required>
                </div>

                <div class="form-group">
                    <label for="confirmPassword" class="form-label">Confirm Password</label>
                    <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="••••••••" required>
                </div>

                <p class="password-hint">Use at least 8 characters with a mix of letters and numbers.</p>

                <button type="submit" class="btn-auth">Update Password</button>
            </form>
        </div>
    </div>

    <%- include('./partials/script')%>
</body>

</html>