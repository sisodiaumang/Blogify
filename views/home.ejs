<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head')%>
    <title>The Feed | Stories & Ideas</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #fcfaf7;
            --accent-color: #2d3e50;
            --text-main: #1a1a1a;
            --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
            --card-hover-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
            --border: #eceae5;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
            box-sizing: border-box;
        }

        .home-header {
            font-family: 'DM Serif Display', serif;
            font-size: clamp(2.2rem, 8vw, 3.5rem);
            color: var(--accent-color);
            margin-top: 60px;
            margin-bottom: 20px;
            letter-spacing: -1px;
            text-align: center;
        }

        /* --- Search Bar --- */
        .search-wrapper {
            max-width: 550px;
            margin: 0 auto 50px auto;
        }

        .search-form {
            display: flex;
            gap: 8px;
            background: #fff;
            padding: 6px;
            border-radius: 50px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            border: 1px solid #eee;
        }

        .search-input {
            flex: 1;
            padding: 10px 20px;
            border: none;
            border-radius: 30px;
            outline: none;
            font-size: 1rem;
            min-width: 0;
        }

        .btn-search {
            background-color: var(--accent-color);
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
        }

        /* --- Blog Grid --- */
        .blog-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 32px;
            padding-bottom: 40px;
        }

        .blog-card {
            background: #ffffff;
            border-radius: 20px;
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
            box-shadow: var(--card-shadow);
            border: 1px solid rgba(0,0,0,0.02);
            transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), 
                        box-shadow 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        .card-img-wrapper {
            width: 100%;
            height: 240px;
            overflow: hidden;
        }

        .blog-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }

        .blog-card-body {
            padding: 24px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .card-category {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #a0a0a0;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .blog-card-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.5rem;
            margin-bottom: 16px;
            color: var(--text-main);
            line-height: 1.25;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .card-footer {
            margin-top: auto;
            display: flex;
            align-items: center;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--accent-color);
            gap: 6px;
        }

        .card-footer svg {
            transition: transform 0.3s ease;
        }

        /* ── Improved Pagination Control Interface ── */
        .pagination-container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            padding: 40px 0 80px 0;
            flex-wrap: wrap;
            border-top: 1px solid var(--border);
            margin-top: 20px;
        }

        .pagination-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            box-sizing: border-box;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: #ffffff;
            color: var(--text-main);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .pagination-link svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.5;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .pagination-link:hover:not(.disabled):not(.active) {
            border-color: var(--text-main);
            background: #fafaf9;
            transform: translateY(-1px);
        }

        .pagination-link.active {
            background: var(--accent-color);
            border-color: var(--accent-color);
            color: #ffffff;
            cursor: default;
            box-shadow: 0 4px 12px rgba(45, 62, 80, 0.15);
        }

        .pagination-link.disabled {
            opacity: 0.35;
            cursor: not-allowed;
            background: #fafaf9;
            border-color: var(--border);
            color: #aaa;
        }

        .pagination-ellipsis {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 44px;
            color: #999;
            font-size: 0.95rem;
            letter-spacing: 1.5px;
            font-weight: 500;
        }

        /* --- HOVER EFFECTS --- */
        @media (hover: hover) {
            .blog-card:hover {
                transform: translateY(-10px);
                box-shadow: var(--card-hover-shadow);
            }

            .blog-card:hover img {
                transform: scale(1.08);
            }

            .blog-card:hover .card-footer svg {
                transform: translateX(4px);
            }
        }

        /* --- MOBILE TWEAKS --- */
        @media (max-width: 768px) {
            .container { padding: 0 20px; }
            .blog-grid { grid-template-columns: 1fr; gap: 24px; }
            .card-img-wrapper { height: 210px; }
            .search-form { padding: 4px; }
            .pagination-link { width: 38px; height: 38px; font-size: 0.85rem; }
        }
    </style>
</head>

<body>
    <%- include('./partials/nav')%>

    <div class="container">
        <header class="home-header">
            Stories <span style="font-style: italic; color: #aaa;">&</span> Ideas
        </header>

        <div class="search-wrapper">
            <form action="/" method="GET" class="search-form">
                <input 
                    type="text" 
                    name="search" 
                    class="search-input" 
                    placeholder="Search articles..." 
                    value="<%= search || '' %>"
                >
                <button type="submit" class="btn-search">Search</button>
            </form>
            <% if (search) { %>
                <div style="margin-top: 16px; text-align: center;">
                    <a href="/" style="color: #666; font-size: 0.85rem; text-decoration: none; display: inline-flex; align-items: center; gap: 4px;">
                        Clear Search Filter
                    </a>
                </div>
            <% } %>
        </div>

        <div class="blog-grid">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach(blog => { %>
                    <a href="/blog/<%= blog._id %>" class="blog-card">
                        <div class="card-img-wrapper">
                            <% if (blog.coverImageURL) { %>
                                <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>">
                            <% } else { %>
                                <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1000" alt="Default">
                            <% } %>
                        </div>
                        
                        <div class="blog-card-body">
                            <div class="card-category">Editorial</div>
                            <h2 class="blog-card-title"><%= blog.title %></h2>
                            <div class="card-footer">
                                Read Article 
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                            </div>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 100px 0;">
                    <h3 style="font-family: 'DM Serif Display', serif; font-size: 1.8rem; margin: 0 0 8px 0;">No stories found</h3>
                    <p class="text-muted" style="margin: 0; color: #666;">Try another keyword or <a href="/" style="color: var(--accent-color); font-weight: 600;">view all posts</a>.</p>
                </div>
            <% } %>
        </div>

        <% if (locals.totalPages && totalPages > 1) { %>
            <% 
                const current = parseInt(currentPage) || 1;
                const searchParam = search ? `&search=${encodeURIComponent(search)}` : '';
            %>
            <nav class="pagination-container" aria-label="Page navigation">
                
                <% if (current > 1) { %>
                    <a href="?page=<%= current - 1 %><%= searchParam %>" class="pagination-link" aria-label="Previous page">
                        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
                    </a>
                <% } else { %>
                    <span class="pagination-link disabled">
                        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
                    </span>
                <% } %>

                <% 
                    let startPage = Math.max(1, current - 1);
                    let endPage = Math.min(totalPages, current + 1);

                    if (current <= 2) {
                        endPage = Math.min(totalPages, 4);
                    }
                    if (current >= totalPages - 1) {
                        startPage = Math.max(1, totalPages - 3);
                    }
                %>

                <% if (startPage > 1) { %>
                    <a href="?page=1<%= searchParam %>" class="pagination-link <%= current === 1 ? 'active' : '' %>">1</a>
                    <% if (startPage > 2) { %>
                        <span class="pagination-ellipsis">&bull;&bull;&bull;</span>
                    <% } %>
                <% } %>

                <% for (let i = startPage; i <= endPage; i++) { %>
                    <a href="?page=<%= i %><%= searchParam %>" class="pagination-link <%= current === i ? 'active' : '' %>"><%= i %></a>
                <% } %>

                <% if (endPage < totalPages) { %>
                    <% if (endPage < totalPages - 1) { %>
                        <span class="pagination-ellipsis">&bull;&bull;&bull;</span>
                    <% } %>
                    <a href="?page=<%= totalPages %><%= searchParam %>" class="pagination-link <%= current === totalPages ? 'active' : '' %>"><%= totalPages %></a>
                <% } %>

                <% if (current < totalPages) { %>
                    <a href="?page=<%= current + 1 %><%= searchParam %>" class="pagination-link" aria-label="Next page">
                        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </a>
                <% } else { %>
                    <span class="pagination-link disabled">
                        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </span>
                <% } %>

            </nav>
        <% } %>
    </div>

    <%- include('./partials/script')%>
</body>
</html>