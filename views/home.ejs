<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head')%>
    <title>The Feed | Stories & Ideas</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <!-- <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
     -->
    <style>
        :root {
            --bg-color: #fcfaf7;
            --accent-color: #2d3e50;
            --text-main: #1a1a1a;
            --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
            --card-hover-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .home-header {
            font-family: 'DM Serif Display', serif;
            font-size: clamp(2.2rem, 8vw, 3.5rem); /* Responsive sizing */
            color: var(--accent-color);
            margin-top: 60px;
            margin-bottom: 20px;
            letter-spacing: -1px;
            text-align: center;
        }

        /* --- Search Bar --- */
        .search-wrapper {
            max-width: 550px;
            margin: 0 auto 50px auto;
        }

        .search-form {
            display: flex;
            gap: 8px;
            background: #fff;
            padding: 6px;
            border-radius: 50px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            border: 1px solid #eee;
        }

        .search-input {
            flex: 1;
            padding: 10px 20px;
            border: none;
            border-radius: 30px;
            outline: none;
            font-size: 1rem;
            min-width: 0;
        }

        .btn-search {
            background-color: var(--accent-color);
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
        }

        /* --- Blog Grid --- */
        .blog-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 32px;
            padding-bottom: 80px;
        }

        /* --- THE CARD (With Re-added Animations) --- */
        .blog-card {
            background: #ffffff;
            border-radius: 20px;
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
            box-shadow: var(--card-shadow);
            border: 1px solid rgba(0,0,0,0.02);
            /* Smooth transition for the lift effect */
            transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), 
                        box-shadow 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        .card-img-wrapper {
            width: 100%;
            height: 240px;
            overflow: hidden;
        }

        .blog-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            /* Smooth transition for the zoom */
            transition: transform 0.6s ease;
        }

        .blog-card-body {
            padding: 24px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .card-category {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #a0a0a0;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .blog-card-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.5rem;
            margin-bottom: 16px;
            color: var(--text-main);
            line-height: 1.25;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .card-footer {
            margin-top: auto;
            display: flex;
            align-items: center;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--accent-color);
        }

        .card-footer i {
            transition: transform 0.3s ease;
        }

        /* --- HOVER EFFECTS (Only for devices that support hover) --- */
        @media (hover: hover) {
            .blog-card:hover {
                transform: translateY(-10px);
                box-shadow: var(--card-hover-shadow);
            }

            .blog-card:hover img {
                transform: scale(1.08);
            }

            .blog-card:hover .card-footer i {
                transform: translateX(6px);
            }
        }

        /* --- MOBILE TWEAKS --- */
        @media (max-width: 768px) {
            .container { padding: 0 20px; }
            .blog-grid { grid-template-columns: 1fr; gap: 24px; }
            .card-img-wrapper { height: 210px; }
            .search-form { padding: 4px; }
        }
    </style>
</head>

<body>
    <%- include('./partials/nav')%>

    <div class="container">
        <header class="home-header">
            Stories <span style="font-style: italic; color: #aaa;">&</span> Ideas
        </header>

        <div class="search-wrapper">
            <form action="/" method="GET" class="search-form">
                <input 
                    type="text" 
                    name="search" 
                    class="search-input" 
                    placeholder="Search articles..." 
                    value="<%= search || '' %>"
                >
                <button type="submit" class="btn-search">Search</button>
            </form>
            <% if (search) { %>
                <div style="margin-top: 12px; text-align: center;">
                    <a href="/" style="color: #888; font-size: 0.85rem; text-decoration: none;">
                        <i class="bi bi-x-circle"></i> Clear Search
                    </a>
                </div>
            <% } %>
        </div>

        <div class="blog-grid">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach(blog => { %>
                    <a href="/blog/<%= blog._id %>" class="blog-card">
                        <div class="card-img-wrapper">
                            <% if (blog.coverImageURL) { %>
                                <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>">
                            <% } else { %>
                                <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1000" alt="Default">
                            <% } %>
                        </div>
                        
                        <div class="blog-card-body">
                            <div class="card-category">Editorial</div>
                            <h2 class="blog-card-title"><%= blog.title %></h2>
                            <div class="card-footer">
                                Read Article <i class="bi bi-arrow-right ms-2"></i>
                            </div>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 100px 0;">
                    <i class="bi bi-journal-x" style="font-size: 3rem; color: #ddd;"></i>
                    <h3 class="mt-3">No stories found</h3>
                    <p class="text-muted">Try another keyword or <a href="/" style="color: var(--accent-color);">view all</a>.</p>
                </div>
            <% } %>
        </div>
    </div>

    <%- include('./partials/script')%>
</body>
</html>