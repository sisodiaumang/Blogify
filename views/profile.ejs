<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head')%>
    <title><%= user.fullName %> | Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --bg-color: #fcfaf7;
            --accent-color: #2d3e50;
            --text-main: #1a1a1a;
            --border-color: #e5e0d8;
            --danger-red: #d85c5c;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
        }

        .profile-container {
            max-width: 800px;
            margin: 60px auto;
            padding: 0 20px;
        }

        /* --- Profile Header --- */
        .profile-header {
            text-align: center;
            margin-bottom: 60px;
        }

        .profile-avatar {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #fff;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            margin-bottom: 25px;
        }

        .profile-name {
            font-family: 'DM Serif Display', serif;
            font-size: 3.5rem;
            color: var(--accent-color);
            margin-bottom: 5px;
            letter-spacing: -1px;
        }

        .archive-label {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: #a0a0a0;
            display: block;
            margin-top: 15px;
        }

        /* --- Action Link --- */
        .action-link {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-decoration: none;
            color: var(--accent-color);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: opacity 0.2s;
        }

        .action-link:hover {
            opacity: 0.7;
        }

        /* --- Article Cards --- */
        .article-card {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 40px 0;
            border-bottom: 1px solid var(--border-color);
            position: relative;
            overflow: hidden;
        }

        .article-info { flex: 1; padding-right: 40px; }

        .article-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.85rem;
            color: var(--text-main);
            text-decoration: none;
            display: block;
            margin-bottom: 12px;
            line-height: 1.2;
        }

        .article-title:hover { color: var(--accent-color); }

        .article-actions { display: flex; gap: 20px; margin-top: 15px; }

        .article-img {
            width: 140px;
            height: 140px;
            object-fit: cover;
            border-radius: 8px;
        }

        /* --- Glassmorphism Delete Overlay --- */
        .delete-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(45, 62, 80, 0.96); 
            backdrop-filter: blur(8px);
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 20px;
            transform: translateX(100%);
            transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);
            z-index: 10;
        }

        .delete-overlay.active { transform: translateX(0); }

        .btn-confirm-delete {
            background: var(--danger-red);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .btn-cancel-delete {
            background: transparent;
            color: white;
            border: 1px solid rgba(255,255,255,0.3);
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
        }
    </style>
</head>

<body>
    <%- include('./partials/nav')%>

    <div class="profile-container">
        <header class="profile-header">
            <img src="<%= user.profileImageURL || 'https://ui-avatars.com/api/?name=' + user.fullName + '&background=2d3e50&color=fff' %>" 
                 alt="Profile" class="profile-avatar">

            <h1 class="profile-name"><%= user.fullName %></h1>

            <div class="mb-3">
                <a href="/user/settings" class="action-link">
                    <i class="bi bi-gear-wide-connected"></i> Edit Profile & Settings
                </a>
            </div>

            <span class="archive-label">
                Archive — <%= blogs.length %> Stories
            </span>
        </header>

        <div class="archive-list">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach(blog => { %>
                    <div class="article-card">
                        
                        <div class="delete-overlay" id="overlay-<%= blog._id %>">
                            <span style="font-family: 'DM Serif Display', serif; font-size: 1.4rem;">Delete this story?</span>
                            <div class="d-flex gap-3">
                                <button class="btn-cancel-delete" onclick="toggleDelete('<%= blog._id %>')">Keep</button>
                                <form action="/blog/delete/<%= blog._id %>?_method=DELETE" method="POST">
                                    <button type="submit" class="btn-confirm-delete">Confirm</button>
                                </form>
                            </div>
                        </div>

                        <div class="article-info">
                            <a href="/blog/<%= blog._id %>" class="article-title"><%= blog.title %></a>
                            <p style="color: #666; font-size: 0.95rem; line-height: 1.6;">
                                <%= blog.body.substring(0, 160) %>...
                            </p>

                            <div class="article-actions">
                                <a href="/blog/edit/<%= blog._id %>" class="action-link" style="color: var(--accent-color);">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <button class="action-link" style="color: var(--danger-red);" onclick="toggleDelete('<%= blog._id %>')">
                                    <i class="bi bi-trash3"></i> Delete
                                </button>
                            </div>
                        </div>

                        <% if (blog.coverImageURL) { %>
                            <img src="<%= blog.coverImageURL %>" alt="Cover" class="article-img">
                        <% } %>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center py-5">
                    <p class="text-muted mb-4">You haven't published any stories yet.</p>
                    <a href="/blog/add-new" class="action-link" style="font-size: 0.9rem; border: 1px solid var(--accent-color); padding: 10px 25px; border-radius: 50px;">
                        Write your first story
                    </a>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        function toggleDelete(id) {
            document.getElementById('overlay-' + id).classList.toggle('active');
        }
    </script>

    <%- include('./partials/script')%>
</body>

</html>