<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head')%>
    <title><%= profileUser.fullName %> | Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --bg-color: #fcfaf7;
            --accent-color: #2d3e50;
            --text-main: #1a1a1a;
            --text-muted: #666;
            --border-color: #e5e0d8;
            --danger-red: #d85c5c;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
        }

        .profile-container {
            max-width: 850px;
            margin: 60px auto;
            padding: 0 24px;
        }

        /* --- Profile Header --- */
        .profile-header {
            text-align: center;
            margin-bottom: 70px;
        }

        .profile-avatar {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #fff;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            margin-bottom: 20px;
        }

        .profile-name {
            font-family: 'DM Serif Display', serif;
            font-size: 3.5rem;
            color: var(--accent-color);
            margin-bottom: 8px;
            letter-spacing: -1.5px;
        }

        .profile-bio {
            max-width: 550px;
            margin: 0 auto 25px;
            color: var(--text-muted);
            line-height: 1.6;
            font-size: 1.1rem;
        }

        .settings-btn {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-decoration: none;
            color: var(--accent-color);
            border: 1px solid var(--border-color);
            padding: 10px 24px;
            border-radius: 50px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

        .settings-btn:hover {
            background: var(--accent-color);
            color: #fff;
            transform: translateY(-2px);
        }

        .archive-label {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 4px;
            color: #b0aba3;
            display: block;
            margin-top: 50px;
        }

        /* --- Article Card (Fixed) --- */
        .article-card {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 40px 0;
            border-bottom: 1px solid var(--border-color);
            position: relative; /* Fixed: Keeps overlay inside */
            overflow: hidden;   /* Fixed: Keeps transition clean */
        }

        .article-info {
            flex: 1;
            padding-right: 40px;
        }

        .article-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.9rem;
            color: var(--text-main);
            text-decoration: none;
            display: block;
            margin-bottom: 10px;
            line-height: 1.2;
        }

        .article-title:hover { color: var(--text-muted); }

        .article-excerpt {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 20px;
        }

        .article-img {
            width: 140px;
            height: 140px;
            object-fit: cover;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .article-actions {
            display: flex;
            gap: 20px;
        }

        .action-btn {
            background: none;
            border: none;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--accent-color);
            text-decoration: none;
            cursor: pointer;
            padding: 0;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .action-btn.delete { color: var(--danger-red); }

        /* --- Delete Overlay (Fixed) --- */
        .delete-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(45, 62, 80, 0.98);
            backdrop-filter: blur(10px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 20px;
            z-index: 10;
            transform: translateX(105%); /* Hidden to the right */
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .delete-overlay.active { transform: translateX(0); }

        .overlay-title {
            font-family: 'DM Serif Display', serif;
            color: white;
            font-size: 1.6rem;
            margin: 0;
        }

        .overlay-btns {
            display: flex;
            gap: 15px;
        }

        .pill-btn {
            padding: 10px 25px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
        }

        .pill-btn-cancel { background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.3); }
        .pill-btn-delete { background: var(--danger-red); color: white; }
    </style>
</head>

<body>
    <%- include('./partials/nav')%>

    <div class="profile-container">
        <header class="profile-header">
            <img src="<%= profileUser.profileImageURL || 'https://ui-avatars.com/api/?name=' + profileUser.fullName + '&background=2d3e50&color=fff' %>"
                 class="profile-avatar">

            <h1 class="profile-name"><%= profileUser.fullName %></h1>

            <% if (profileUser.bio) { %>
                <p class="profile-bio"><%= profileUser.bio %></p>
            <% } %>

            <% if (locals.user && locals.user._id.toString() === profileUser._id.toString()) { %>
                <a href="/user/settings" class="settings-btn">
                    <i class="bi bi-gear-fill"></i> Settings
                </a>
            <% } %>

            <span class="archive-label">The Archive &mdash; <%= blogs.length %> Stories</span>
        </header>

        <div class="archive-list">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach(blog => { %>
                    <div class="article-card">
                        
                        <% if (locals.user && locals.user._id.toString() === blog.createdBy.toString()) { %>
                            <div class="delete-overlay" id="overlay-<%= blog._id %>">
                                <h3 class="overlay-title">Delete this story?</h3>
                                <div class="overlay-btns">
                                    <button class="pill-btn pill-btn-cancel" onclick="toggleDelete('<%= blog._id %>')">Keep Story</button>
                                    <form action="/blog/delete/<%= blog._id %>?_method=DELETE" method="POST" style="margin:0;">
                                        <button type="submit" class="pill-btn pill-btn-delete">Confirm Delete</button>
                                    </form>
                                </div>
                            </div>
                        <% } %>

                        <div class="article-info">
                            <a href="/blog/<%= blog._id %>" class="article-title"><%= blog.title %></a>
                            <p class="article-excerpt">
                                <%= blog.body.replace(/[#*`]/g, '').substring(0, 150) %>...
                            </p>

                            <% if (locals.user && locals.user._id.toString() === blog.createdBy.toString()) { %>
                                <div class="article-actions">
                                    <a href="/blog/edit/<%= blog._id %>" class="action-btn">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <button class="action-btn delete" onclick="toggleDelete('<%= blog._id %>')">
                                        <i class="bi bi-trash3"></i> Delete
                                    </button>
                                </div>
                            <% } %>
                        </div>

                        <% if (blog.coverImageURL) { %>
                            <img src="<%= blog.coverImageURL %>" class="article-img">
                        <% } %>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="text-align: center; opacity: 0.4; padding: 100px 0;">
                    <i class="bi bi-feather fs-1"></i>
                    <p class="mt-3">Silence. No stories published yet.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        function toggleDelete(id) {
            const el = document.getElementById('overlay-' + id);
            if(el) el.classList.toggle('active');
        }
    </script>
    <%- include('./partials/script')%>
</body>
</html>