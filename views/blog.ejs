        // в”Җв”Җ Picker state в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        let activePicker = null;
        let activeTextareaId = null;
        const renderedPickers = new Set();

        function buildPicker(pickerId, textareaId) {
            if (renderedPickers.has(pickerId)) return;
            renderedPickers.add(pickerId);

            const popup = document.getElementById(pickerId);
            let activeTab = 0;

            function renderGrid(emojis) {
                return emojis.map(e =>
                    `<span class="emoji-cell" onclick="insertEmoji('${textareaId}','${e}')">${e}</span>`
                ).join('');
            }

            function renderCategory(idx) {
                popup.querySelector('.emoji-grid').innerHTML = renderGrid(EMOJI_CATEGORIES[idx].emojis);
                popup.querySelectorAll('.emoji-tab').forEach((t, i) => t.classList.toggle('active', i === idx));
                activeTab = idx;
            }

            const tabs = EMOJI_CATEGORIES.map((cat, i) =>
                `<button class="emoji-tab${i === 0 ? ' active' : ''}" type="button" onclick="pickerTabClick('${pickerId}',${i})" title="${cat.name}">${cat.label}</button>`
            ).join('');

            popup.innerHTML = `
                <div class="emoji-tabs">${tabs}</div>
                <div class="emoji-search"><input type="text" placeholder="Search emojisвҖҰ" oninput="pickerSearch('${pickerId}','${textareaId}',this.value)"></div>
                <div class="emoji-grid">${renderGrid(EMOJI_CATEGORIES[0].emojis)}</div>
            `;

            popup._renderCategory = renderCategory;
        }

        function pickerTabClick(pickerId, idx) {
            const popup = document.getElementById(pickerId);
            if (popup._renderCategory) popup._renderCategory(idx);
        }

        function pickerSearch(pickerId, textareaId, query) {
            const popup = document.getElementById(pickerId);
            const grid = popup.querySelector('.emoji-grid');
            if (!query.trim()) {
                if (popup._renderCategory) popup._renderCategory(0);
                return;
            }
            const all = EMOJI_CATEGORIES.flatMap(c => c.emojis);
            const results = all.filter((e) => {
                const catName = EMOJI_CATEGORIES.find(c => c.emojis.includes(e))?.name.toLowerCase() || '';
                return catName.includes(query.toLowerCase());
            });
            grid.innerHTML = (results.length ? results : all).map(e =>
                `<span class="emoji-cell" onclick="insertEmoji('${textareaId}','${e}')">${e}</span>`
            ).join('');
        }

        function togglePicker(pickerId, textareaId) {
    if (activePicker && activePicker !== pickerId) {
        const prev = document.getElementById(activePicker);
        if (prev) prev.classList.remove('open');
    }

    const popup = document.getElementById(pickerId);
    const btn   = popup.previousElementSibling;
    const isOpen = popup.classList.contains('open');

    if (!isOpen) {
        buildPicker(pickerId, textareaId);

        // Make visible but off-screen first to measure real height
        popup.style.visibility = 'hidden';
        popup.style.display = 'block';
        const pickerH = popup.offsetHeight || 310;
        const pickerW = window.innerWidth <= 640 ? window.innerWidth - 16 : 300;
        popup.style.display = '';
        popup.style.visibility = '';

        popup.classList.add('open');

        const rect = btn.getBoundingClientRect();
        const isMobile = window.innerWidth <= 640;

        if (isMobile) {
            const spaceAbove = rect.top;
            const spaceBelow = window.innerHeight - rect.bottom;

            let top;
            if (spaceAbove >= pickerH + 8) {
                // Enough room above вҖ” open upward
                top = rect.top - pickerH - 8;
            } else if (spaceBelow >= pickerH + 8) {
                // Enough room below вҖ” open downward
                top = rect.bottom + 8;
            } else {
                // Neither fits cleanly вҖ” center vertically in viewport
                top = Math.max(8, (window.innerHeight - pickerH) / 2);
            }

            // Clamp so it never goes off top or bottom
            top = Math.max(8, Math.min(top, window.innerHeight - pickerH - 8));

            popup.style.position = 'fixed';
            popup.style.top  = top + 'px';
            popup.style.left = '8px';
            popup.style.width = pickerW + 'px';

        } else {
            const spaceBelow = window.innerHeight - rect.bottom;
            let top, left;

            if (spaceBelow >= pickerH + 8) {
                top = rect.bottom + 6;
            } else {
                top = rect.top - pickerH - 6;
            }

            // Clamp so it never goes off top or bottom
            top = Math.max(8, Math.min(top, window.innerHeight - pickerH - 8));

            left = Math.min(rect.right - pickerW, window.innerWidth - pickerW - 8);
            left = Math.max(8, left);

            popup.style.position = 'fixed';
            popup.style.top  = top + 'px';
            popup.style.left = left + 'px';
            popup.style.width = pickerW + 'px';
        }

        activePicker = pickerId;
        activeTextareaId = textareaId;
    } else {
        popup.classList.remove('open');
        activePicker = null;
        activeTextareaId = null;
    }
}

        function insertEmoji(textareaId, emoji) {
            const ta = document.getElementById(textareaId);
            if (!ta) return;
            const start = ta.selectionStart;
            const end   = ta.selectionEnd;
            ta.value = ta.value.slice(0, start) + emoji + ta.value.slice(end);
            ta.selectionStart = ta.selectionEnd = start + emoji.length;
            ta.focus();
        }

        document.addEventListener('click', function(e) {
            if (!e.target.closest('.emoji-picker-popup') && !e.target.closest('.emoji-btn')) {
                document.querySelectorAll('.emoji-picker-popup.open').forEach(p => p.classList.remove('open'));
                activePicker = null;
            }
        });

        // в”Җв”Җ Report Modal в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        let reportTarget = { type: null, id: null };

        const REASON_LABELS = {
            sexual_content: 'Sexual content',
            harassment:     'Harassment or bullying',
            hate_speech:    'Hate speech or discrimination',
            misinformation: 'Misinformation',
            violence:       'Violence or dangerous content',
            spam:           'Spam or scam',
            copyright:      'Copyright or plagiarism',
            other:          'Other'
        };

        function openReportModal(type, id) {
            reportTarget = { type, id };
            document.querySelectorAll('input[name="report-reason"]').forEach(r => r.checked = false);
            document.getElementById('report-details-input').value = '';
            document.getElementById('report-char-count').textContent = '0';
            document.getElementById('report-next-btn').disabled = true;
            showStep(1);
            const submitBtn = document.getElementById('report-submit-btn');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit Report';
            document.getElementById('report-overlay').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeReportModal() {
            document.getElementById('report-overlay').classList.remove('open');
            document.body.style.overflow = '';
        }

        function handleOverlayClick(e) {
            if (e.target === document.getElementById('report-overlay')) {
                closeReportModal();
            }
        }

        function showStep(n) {
            document.querySelectorAll('.report-step').forEach(s => s.classList.remove('active'));
            document.getElementById('report-step-' + n).classList.add('active');
        }

        function onReasonChange() {
            document.getElementById('report-next-btn').disabled = false;
        }

        function goToStep2() {
            const selected = document.querySelector('input[name="report-reason"]:checked');
            if (!selected) return;
            document.getElementById('report-selected-label').textContent = REASON_LABELS[selected.value] || selected.value;
            showStep(2);
        }

        function goToStep1() {
            showStep(1);
        }

        function updateCharCount() {
            const val = document.getElementById('report-details-input').value;
            document.getElementById('report-char-count').textContent = val.length;
        }

        async function submitReport() {
            const reason  = document.querySelector('input[name="report-reason"]:checked')?.value;
            const details = document.getElementById('report-details-input').value.trim();
            const btn     = document.getElementById('report-submit-btn');

            if (!reason) return;

            btn.disabled = true;
            btn.textContent = 'Submitting...';

            try {
                const res = await fetch('/blog/report', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        targetType: reportTarget.type,
                        targetId: reportTarget.id,
                        blogId: '<%= blog._id %>',
                        reason,
                        details
                    })
                });
                if (res.ok) {
                    showStep(3);
                } else {
                    const data = await res.json().catch(() => ({}));
                    alert(data.error || 'Something went wrong. Please try again.');
                    btn.disabled = false;
                    btn.textContent = 'Submit Report';
                }
            } catch (err) {
                console.error('Report error:', err);
                alert('Network error. Please check your connection and try again.');
                btn.disabled = false;
                btn.textContent = 'Submit Report';
            }
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && document.getElementById('report-overlay').classList.contains('open')) {
                closeReportModal();
            }
        });

        // в”Җв”Җ Layout adjustments & Existing handlers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        function setInitialRepliesState() {
            document.querySelectorAll('.replies-list').forEach(el => {
                if(!el.classList.contains('collapsed')) {
                    el.style.maxHeight = el.scrollHeight + 'px';
                }
            });
        }
        window.addEventListener('load', setInitialRepliesState);
        window.addEventListener('resize', () => {
            document.querySelectorAll('.replies-list').forEach(el => {
                if(!el.classList.contains('collapsed')) {
                    el.style.maxHeight = 'none';
                    el.style.maxHeight = el.scrollHeight + 'px';
                }
            });
        });

        function toggleReplies(commentId, count) {
            const list = document.getElementById('replies-list-' + commentId);
            const btn  = document.getElementById('toggle-btn-' + commentId);
            const lbl  = document.getElementById('toggle-label-' + commentId);
            const replyWord = count === 1 ? 'reply' : 'replies';

            if (list.classList.contains('collapsed')) {
                list.style.maxHeight = list.scrollHeight + 'px';
                list.classList.remove('collapsed');
                btn.classList.add('open');
                lbl.textContent = count + ' ' + replyWord;
            } else {
                list.style.maxHeight = list.scrollHeight + 'px';
                requestAnimationFrame(() => { list.classList.add('collapsed'); });
                btn.classList.remove('open');
                lbl.textContent = 'Show ' + count + ' ' + replyWord;
            }
        }

        function toggleDropdown(id) {
            document.querySelectorAll('.dropdown-content').forEach(el => {
                if (el.id !== id) el.classList.remove('show');
            });
            document.getElementById(id).classList.toggle('show');
        }

        window.onclick = function(e) {
            if (!e.target.closest('.dots-menu')) {
                document.querySelectorAll('.dropdown-content').forEach(el => el.classList.remove('show'));
            }
        }

        function enableReply(parentId, targetId, mention) {
            document.querySelectorAll('.reply-area').forEach(el => {
                if (el.id !== 'reply-area-' + parentId) el.style.display = 'none';
            });
            const area  = document.getElementById('reply-area-' + parentId);
            const input = document.getElementById('reply-input-' + parentId);
            area.style.display = 'block';
            if (mention) {
                input.value = mention;
                input.focus();
                input.setSelectionRange(input.value.length, input.value.length);
            } else {
                input.value = '';
                input.focus();
            }
        }

        function cancelReply(parentId) {
            document.getElementById('reply-area-' + parentId).style.display = 'none';
            document.getElementById('reply-input-' + parentId).value = '';
        }

        async function submitReply(parentId) {
            const replyContent = document.getElementById('reply-input-' + parentId).value;
            if (!replyContent.trim()) return alert("Reply cannot be empty");
            try {
                const res = await fetch(`/blog/comment/reply/${parentId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: replyContent })
                });
                if (res.ok) { window.location.reload(); }
                else { alert("Server error: Could not post reply"); }
            } catch (err) { console.error("Fetch error:", err); }
        }

        function enableEdit(id) {
            document.getElementById('text-' + id).style.display = 'none';
            document.getElementById('edit-area-' + id).style.display = 'block';
        }

        function cancelEdit(id) {
            document.getElementById('text-' + id).style.display = 'block';
            document.getElementById('edit-area-' + id).style.display = 'none';
        }

        async function saveEdit(id) {
            const newContent = document.getElementById('input-' + id).value;
            if (!newContent.trim()) return alert("Comment cannot be empty");
            try {
                const res = await fetch(`/blog/comment/edit/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: newContent })
                });
                if (res.ok) {
                    document.getElementById('text-' + id).innerText = newContent;
                    cancelEdit(id);
                } else { alert("Server error: Could not save comment"); }
            } catch (err) {
                console.error("Fetch error:", err);
                alert("Network error: Check your console");
            }
        }

        async function deleteComment(id) {
            if (confirm("Delete this comment?")) {
                const res = await fetch(`/blog/comment/delete/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    document.getElementById('comment-container-' + id).remove();
                } else {
                    const data = await res.json();
                    alert(data.error || "Failed to delete");
                }
            }
        }
    </script>
</body>
</html>